    },
    {
      "parameters": {
        "jsCode": "const text = $input.first().json.text;\nlet parsed;\ntry {\n  const cleanText = text.replace(/```json/g, '').replace(/```/g, '').trim();\n  parsed = JSON.parse(cleanText);\n} catch (error) {\n  throw new Error(\"Failed to parse Gemini output: \" + text);\n}\n\n// We must return the _id so MongoDB knows exactly which task to update\nreturn { \n  json: { \n    _id: $('Fetch Missed Tasks').first().json._id, \n    scheduled_start: parsed.scheduled_start, \n    scheduled_end: parsed.scheduled_end,\n    reasoning: parsed.reasoning\n  } \n};"
      },
