    {
      "parameters": {
        "prompt": "={\n  \"role\": \"system\",\n  \"instructions\": \"You are the LifeSyncPro Rescheduling Engine. Your ONLY job is to take a missed task and assign it a new 'scheduled_start' and 'scheduled_end' time based strictly on the provided rules. You must output raw JSON only.\",\n  \"inputs\": {\n    \"current_time\": \"{{ $now.toISO() }}\",\n    \"missed_task\": {{ JSON.stringify($('Fetch Missed Tasks').first().json) }},\n    \"user_habit_profile\": {{ JSON.stringify($('Fetch User Profile').item.json) }},\n    \"existing_schedule\": {{ JSON.stringify($input.all().map(i => i.json)) }}\n  },\n  \"rules\": [\n    \"1. DURATION: Calculate the exact duration of the 'missed_task' (end - start). The new scheduled block MUST be the exact same length.\",\n    \"2. DEADLINE: If the 'missed_task' has a 'due_date', the new 'scheduled_end' MUST be before the 'due_date'. If impossible, return an error object.\",\n    \"3. SLEEP: The new block MUST NOT overlap with the 'inferred_sleep_window'.\",\n    \"4. HARD BLOCKS: The new block MUST NOT overlap with any 'weekly_hard_blocks'.\",\n    \"5. CONFLICTS: The new block MUST NOT overlap with any times in the 'existing_schedule'.\",\n    \"6. OPTIMIZATION: Attempt to place the new block within the 'peak_productivity_windows'. If impossible, find the next earliest available free slot.\",\n    \"7. SLUMP: Avoid the 'high_ignore_probability_windows' unless absolutely necessary to meet a deadline.\"\n  ],\n  \"expected_output_format\": {\n    \"_id\": \"string\",\n    \"scheduled_start\": \"ISO 8601 Timestamp\",\n    \"scheduled_end\": \"ISO 8601 Timestamp\",\n    \"reasoning\": \"A 1-sentence explanation of why you chose this slot\"\n  }\n}"
      },
      "id": "7c37b4cc-eb50-4319-8526-23a322d8e8e2",
      "name": "Basic LLM Chain",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1,
