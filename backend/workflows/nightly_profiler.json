    {
      "parameters": {
        "jsCode": "const tasks = $input.all().map(item => {\n  let cleanTask = item.json;\n  \n  // Delete the heavy, useless data before sending to Gemini\n  delete cleanTask.embedding; \n  delete cleanTask._id;\n  \n  return cleanTask;\n});\n\nreturn { json: { task_history: JSON.stringify(tasks) } };"
      },
      "id": "1caca353-e1e2-4cf9-966b-f8e8ff540256",
      "name": "Compress Data",
      "type": "n8n-nodes-base.code",
